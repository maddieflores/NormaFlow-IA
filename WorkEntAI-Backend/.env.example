# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env al repositorio

# Groq API Key — obtén una en https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo de IA (opcional, por defecto llama-3.3-70b-versatile)
# AI_MODEL=llama-3.3-70b-versatile

# MongoDB Atlas URI
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/workflow_db

# JWT Secret — usa una cadena larga y aleatoria
JWT_SECRET=cambia_esto_por_una_clave_secreta_muy_larga_123456789

# JWT Expiration en ms (opcional, por defecto 86400000 = 24h)
# JWT_EXPIRATION=86400000

# Puerto del servidor (opcional, por defecto 8080)
# PORT=8080

# Firebase FCM (opcional, por defecto true)
# FCM_ENABLED=true

# CORS — orígenes permitidos (separados por coma)
# En producción pon tu URL de Netlify, ej: https://tu-sitio.netlify.app
# CORS_ALLOWED_ORIGINS=https://tu-sitio.netlify.app
